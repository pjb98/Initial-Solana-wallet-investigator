[Unit]
Description=Solana wallet investigator dashboard
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/solana-wallet-investigator
EnvironmentFile=-/root/solana-wallet-investigator/.env
ExecStart=/root/solana-wallet-investigator/venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8010
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
